[Unit]
Description=Alertmanager ({{ prometheus_alertmanager_identifier }})
{% for service in prometheus_alertmanager_systemd_required_services_list %}
Requires={{ service }}
After={{ service }}
{% endfor %}
{% for service in prometheus_alertmanager_systemd_wanted_services_list %}
Wants={{ service }}
{% endfor %}
DefaultDependencies=no

[Service]
Type=simple
Environment="HOME={{ devture_systemd_docker_base_systemd_unit_home_path }}"
ExecStartPre={{ devture_systemd_docker_base_host_command_sh }} -c '{{ prometheus_alertmanager_container_cleanup_command | trim | replace("\n", " ") }}'

ExecStartPre={{ devture_systemd_docker_base_host_command_docker }} create \
      --rm \
      --name={{ prometheus_alertmanager_identifier }} \
      --log-driver=none \
      --user={{ prometheus_alertmanager_uid }}:{{ prometheus_alertmanager_gid }} \
      --cap-drop=ALL \
      --read-only \
      --network={{ prometheus_alertmanager_container_network }} \
      {% if prometheus_alertmanager_container_http_host_bind_port %}
      -p {{ prometheus_alertmanager_container_http_host_bind_port }}:{{ prometheus_alertmanager_container_http_port }} \
      {% endif %}
      --env-file={{ prometheus_alertmanager_base_path }}/env \
      --label-file={{ prometheus_alertmanager_base_path }}/labels \
      --mount type=bind,src={{ prometheus_alertmanager_config_path }},dst=/etc/alertmanager \
      --mount type=bind,src={{ prometheus_alertmanager_data_path }},dst=/alertmanager \
      {% for arg in prometheus_alertmanager_container_extra_arguments %}
      {{ arg }} \
      {% endfor %}
      {{ prometheus_alertmanager_container_image }} \
      {{ prometheus_alertmanager_process_extra_arguments | join(' ') }}

{% for network in prometheus_alertmanager_container_additional_networks %}
ExecStartPre={{ devture_systemd_docker_base_host_command_docker }} network connect {{ network }} {{ prometheus_alertmanager_identifier }}
{% endfor %}

ExecStart={{ devture_systemd_docker_base_host_command_docker }} start --attach {{ prometheus_alertmanager_identifier }}

ExecStop=-{{ devture_systemd_docker_base_host_command_sh }} -c '{{ devture_systemd_docker_base_host_command_docker }} stop -t {{ devture_systemd_docker_base_container_stop_grace_time_seconds }} {{ prometheus_alertmanager_identifier }} 2>/dev/null || true'
ExecStop=-{{ devture_systemd_docker_base_host_command_sh }} -c '{{ devture_systemd_docker_base_host_command_docker }} rm {{ prometheus_alertmanager_identifier }} 2>/dev/null || true'

Restart=always
RestartSec=30
SyslogIdentifier={{ prometheus_alertmanager_identifier }}

[Install]
WantedBy=multi-user.target
